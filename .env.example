# ─────────────────────────────────────────────────────────────────────────────
# WinProp API — environment. Copy real values in; this file is gitignored.
# ⚠️ The API FAILS TO BOOT unless the REQUIRED secrets below are set to real
#    values (no dev-secret / whsec_dummy). See docs/GO-LIVE.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED (boot fails without these) ──────────────────────────────────────
# Postgres connection string
DATABASE_URL=

# JWT signing secret — must be >= 32 chars and NOT "dev-secret".
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# 64 hex chars (32 bytes) — encrypts the stored LLM API key at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Allowed web origin(s), comma-separated. Used for CORS + CSRF Origin check +
# Stripe redirect + share-link base. e.g. https://app.winprop.ai
WEB_ORIGIN=

# Stripe API secret (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret — the REAL value (NOT whsec_dummy).
# Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# ── STRIPE PLAN PRICE IDS (recurring prices from the Stripe Dashboard) ────────
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_AGENCY=

# ── SUPER-ADMIN ───────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=root@winprop.ai
# Strong password — REQUIRED when seeding in production (pnpm prisma db seed).
SUPER_ADMIN_PASSWORD=
# (Optional, recommended) separate signing secret for super-admin tokens so a
# leak of JWT_SECRET can't mint admin tokens. Generate like JWT_SECRET.
SUPER_ADMIN_JWT_SECRET=
# (Optional) comma-separated IP allow-list for the /admin surface. Empty = any IP.
SUPER_ADMIN_IPS=
# (Optional) super-admin token lifetime. Default 1h.
SUPER_ADMIN_TOKEN_TTL=1h

# ── OPTIONAL / TUNING (sensible defaults shown) ───────────────────────────────
# production | development | test
NODE_ENV=production
PORT=3001
# Base URL for public proposal share links. Defaults to <WEB_ORIGIN>/p if unset.
PROPOSAL_SHARE_BASE_URL=
# Platform LLM spend circuit-breaker — max total USD/day across all orgs. Default 100.
LLM_DAILY_USD_CAP=100
# Dev/demo only: when "true", proposal generation uses a built-in mock provider
# that returns canned, well-formed proposals (no upstream LLM key needed).
# Leave empty/false in production.
LLM_MOCK=
# Email (Resend). Both must be set to actually send verification emails;
# otherwise mail is dev-logged (and warned in prod). MAIL_FROM must be a Resend-verified sender.
RESEND_API_KEY=
MAIL_FROM=
# Stripe webhook inbox drain interval (ms). Default 30000.
WEBHOOK_DRAIN_INTERVAL_MS=30000
# Reclaim webhook rows stuck "processing" after this many ms. Default 120000.
WEBHOOK_STUCK_AFTER_MS=120000
# DO NOT set to 1 in production — kill-switch is ignored in prod anyway. Tests only.
# THROTTLE_DISABLED=
