# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL connection string (managed DB: Railway, Render, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/winprop

# Secret used to sign JWT tokens — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# 64-char hex key used to encrypt LLM API keys at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_with_64_hex_chars_from_command_above

# Allowed CORS origin for the web frontend (set to your Vercel URL after deploy)
WEB_ORIGIN=https://your-app.vercel.app

# Stripe secret key (test mode starts with sk_test_, live with sk_live_)
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret — copy from Stripe Dashboard after adding endpoint
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Stripe recurring Price IDs (test mode) — create in Stripe Dashboard > Products
STRIPE_PRICE_SOLO=price_replace_solo_id
STRIPE_PRICE_PRO=price_replace_pro_id
STRIPE_PRICE_AGENCY=price_replace_agency_id

# (Optional) Server port. Defaults to 3001 if not set.
PORT=3001

# (Optional) Email for the super-admin row created by `pnpm prisma db seed`.
# Defaults to root@winprop.ai if not set.
SUPER_ADMIN_EMAIL=root@winprop.ai
