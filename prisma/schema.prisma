generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Profession {
  developer
  designer
  writer
  sales
  marketer
  consultant
  video
}

enum Role {
  owner
  admin
  member
  viewer
}

enum Plan {
  free
  solo
  pro
  agency
}

enum JobStatus {
  draft
  proposal_generated
  sent
  viewed
  negotiation
  won
  lost
}

enum DocType {
  proposal
}

enum DocStatus {
  draft
  ready
}

enum LlmVendor {
  openai
  anthropic
}

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String
  name              String
  preferredLanguage String?
  createdAt         DateTime       @default(now())
  memberships       Membership[]
  refreshTokens     RefreshToken[]
}

// H5: server-side refresh-token store for hard revocation + rotation. Each issued
// refresh JWT carries a `jti` matching a row here. Refresh rotates (revokes the old
// jti, issues a new one); presenting an already-revoked jti is treated as token
// theft and revokes the user's whole chain. Logout revokes the presented jti.
model RefreshToken {
  id           String    @id @default(cuid())
  jti          String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt    DateTime?
  replacedById String?   // jti that superseded this one (rotation chain)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Org {
  id               String          @id @default(cuid())
  name             String
  profession       Profession
  createdAt        DateTime        @default(now())
  stripeCustomerId String?
  plan             Plan            @default(free)
  subStatus        String?
  memberships      Membership[]
  profile          Profile?
  jobs             Job[]
  subscription     Subscription?
  generationLogs   GenerationLog[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   Role
  user   User   @relation(fields: [userId], references: [id])
  org    Org    @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
}

model Profile {
  id            String   @id @default(cuid())
  orgId         String   @unique
  org           Org      @relation(fields: [orgId], references: [id])
  services      String[]
  skills        String[]
  priceMin      Int      @default(5000)
  priceMax      Int      @default(40000)
  tone          String   @default("premium")
  brandColor    String   @default("#6366F1")
  brandShort    String   @default("WP")
  agencyName    String
  // Rich brand + credibility data (V1) — biggest lever on proposal quality.
  logoUrl       String?
  website       String?
  contactInfo   String?
  portfolioLinks String[] @default([])
  caseStudies   Json? // [{ title, summary, url? }]
  testimonials  Json? // [{ author, quote, company? }]
}

model Job {
  id                 String     @id @default(cuid())
  orgId              String
  org                Org        @relation(fields: [orgId], references: [id])
  title              String
  company            String     @default("—")
  // Rich client + opportunity data (V1) — feeds proposal-generation quality.
  clientName         String?
  clientEmail        String?
  clientWebsite      String?
  projectDescription String?
  requirements       String?
  budget             Int? // whole currency units, nullable
  timeline           String? // free text, e.g. "6 weeks"
  status             JobStatus  @default(draft)
  createdAt          DateTime   @default(now())
  documents          Document[]
}

model Document {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  type        DocType           @default(proposal)
  title       String
  contentJson Json
  version     Int               @default(1)
  status      DocStatus         @default(draft)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  // Public share link (V1). Null = not shared; set = readable at /p/:token.
  shareToken  String?           @unique
  versions    DocumentVersion[]
}

// Snapshot of a document's content before an edit overwrote it (editor history, V1).
model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  contentJson Json
  createdAt   DateTime @default(now())

  @@index([documentId])
}

model Subscription {
  id               String   @id @default(cuid())
  orgId            String   @unique
  org              Org      @relation(fields: [orgId], references: [id])
  stripeSubId      String   @unique
  stripePriceId    String
  status           String
  currentPeriodEnd DateTime
}

model LlmConfig {
  id              String    @id @default(cuid())
  orgId           String?   @unique
  provider        LlmVendor
  apiKeyEncrypted String
  model           String
  updatedAt       DateTime  @updatedAt
}

model GenerationLog {
  id               String   @id @default(cuid())
  orgId            String
  org              Org      @relation(fields: [orgId], references: [id])
  jobId            String
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Decimal  @db.Decimal(10, 6)
  priceMapVersion  String
  createdAt        DateTime @default(now())
}

model SuperAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  // H3: real auth. Nullable so the legacy seed row keeps working until a password
  // is set; login is refused for rows without a hash.
  passwordHash String?
  createdAt    DateTime            @default(now())
  auditLogs    SuperAdminAuditLog[]
}

// H3: audit trail for the super-admin surface. Every authenticated /admin call is
// recorded (never the request body — it can carry secrets like LLM API keys).
model SuperAdminAuditLog {
  id           String     @id @default(cuid())
  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  action       String     // e.g. "PUT /admin/llm-config"
  ip           String?
  createdAt    DateTime   @default(now())

  @@index([superAdminId, createdAt])
}

// Atomic per-period quota counter (H2). Replaces counting GenerationLog rows,
// which had a check-then-insert race: two concurrent generations at the limit
// boundary could both pass. The guard reserves a slot with a single atomic
// INSERT .. ON CONFLICT DO UPDATE .. WHERE used < limit, so concurrency can
// never exceed the plan limit. A failed generation releases its reservation.
model QuotaPeriod {
  id          String   @id @default(cuid())
  orgId       String
  periodStart DateTime
  used        Int      @default(0)

  @@unique([orgId, periodStart])
}

model ProcessedEvent {
  id        String   @id            // Stripe event id
  createdAt DateTime @default(now())
}

enum WebhookStatus {
  pending
  processing
  done
  failed
}

// Durable inbox for Stripe webhooks (H1). The webhook endpoint verifies the
// signature, persists the event here, and acks immediately (202). A background
// processor drains pending rows — so a slow/failed DB write can no longer make
// Stripe time out and retry, and unprocessed events survive a crash/restart.
model WebhookEvent {
  id          String        @id            // Stripe event id (dedup key)
  type        String
  payload     Json
  status      WebhookStatus @default(pending)
  attempts    Int           @default(0)
  lastError   String?
  createdAt   DateTime      @default(now())
  claimedAt   DateTime?     // when a worker last took the row into `processing`
  processedAt DateTime?

  @@index([status])
}
