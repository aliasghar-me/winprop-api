generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Profession {
  developer
  designer
  writer
  sales
  marketer
  consultant
  video
}

enum Role {
  owner
  admin
  member
  viewer
}

enum Plan {
  free
  starter
  professional
  agency
  enterprise
}

enum JobStatus {
  draft
  proposal_generated
  sent
  viewed
  negotiation
  won
  lost
}

enum DocType {
  proposal
  sow
  estimate
}

enum DocStatus {
  draft
  ready
}

enum LlmVendor {
  openai
  anthropic
}

model User {
  id                String         @id @default(cuid())
  // PII at rest (security #16): email + name are AES-256-GCM ciphertext. Lookups
  // use emailHash (deterministic HMAC blind index) since the ciphertext varies.
  email             String
  emailHash         String?        @unique
  passwordHash      String
  name              String
  preferredLanguage String?
  createdAt         DateTime       @default(now())
  // Account lockout (security #5)
  failedLoginCount  Int            @default(0)
  lockedUntil       DateTime?
  // Email verification (security #1): null until the user confirms their address.
  emailVerifiedAt   DateTime?
  memberships       Membership[]
  refreshTokens     RefreshToken[]
  emailVerifications EmailVerificationToken[]
}

// Single-use, short-lived email-verification tokens. Only the SHA-256 hash of the
// raw token is stored, so a DB leak can't be used to verify accounts (security #1).
model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// H5: server-side refresh-token store for hard revocation + rotation. Each issued
// refresh JWT carries a `jti` matching a row here. Refresh rotates (revokes the old
// jti, issues a new one); presenting an already-revoked jti is treated as token
// theft and revokes the user's whole chain. Logout revokes the presented jti.
model RefreshToken {
  id           String    @id @default(cuid())
  jti          String    @unique
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  revokedAt    DateTime?
  replacedById String?   // jti that superseded this one (rotation chain)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model Org {
  id               String          @id @default(cuid())
  name             String
  profession       Profession
  createdAt        DateTime        @default(now())
  stripeCustomerId String?
  plan             Plan            @default(free)
  subStatus        String?
  memberships      Membership[]
  profile          Profile?
  jobs             Job[]
  subscription     Subscription?
  generationLogs   GenerationLog[]
  userMemories     UserMemory[]
  memoryAuditLogs  MemoryAuditLog[]
}

model Membership {
  id     String @id @default(cuid())
  userId String
  orgId  String
  role   Role
  user   User   @relation(fields: [userId], references: [id])
  org    Org    @relation(fields: [orgId], references: [id])

  @@unique([userId, orgId])
}

model Profile {
  id            String   @id @default(cuid())
  orgId         String   @unique
  org           Org      @relation(fields: [orgId], references: [id])
  services      String[]
  skills        String[]
  priceMin      Int      @default(5000)
  priceMax      Int      @default(40000)
  tone          String   @default("premium")
  brandColor    String   @default("#6366F1")
  brandShort    String   @default("WP")
  agencyName    String
  // Rich brand + credibility data (V1) — biggest lever on proposal quality.
  logoUrl       String?
  website       String?
  contactInfo   String?
  portfolioLinks String[] @default([])
  caseStudies   Json? // [{ title, summary, url? }]
  testimonials  Json? // [{ author, quote, company? }]
}

model Job {
  id                 String     @id @default(cuid())
  orgId              String
  org                Org        @relation(fields: [orgId], references: [id])
  title              String
  company            String     @default("—")
  // Rich client + opportunity data (V1) — feeds proposal-generation quality.
  clientName         String?
  clientEmail        String?
  clientWebsite      String?
  projectDescription String?
  requirements       String?
  budget             Int? // whole currency units, nullable
  timeline           String? // free text, e.g. "6 weeks"
  // AI Job-Intelligence analysis (Phase-1): objective, stack, deliverables, risks,
  // clarification questions, win-probability. Generated on demand, grounded in the job text.
  intelligenceJson   Json?
  status             JobStatus  @default(draft)
  // Outcome recording (Should-I-Apply MVP): set when a deal is won/lost so the
  // Revenue dashboard can compute Revenue Won + revenue-per-proposal.
  wonAmountUsd       Int? // whole USD awarded, set on a won deal
  outcomeReason      String? // free text: why it was won/lost (seeds the learning loop)
  createdAt          DateTime   @default(now())
  documents          Document[]
}

model Document {
  id          String            @id @default(cuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  type        DocType           @default(proposal)
  title       String
  contentJson Json
  version     Int               @default(1)
  status      DocStatus         @default(draft)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @default(now()) @updatedAt
  // Public share link (V1). Null = not shared; set = readable at /p/:token.
  shareToken  String?           @unique
  versions    DocumentVersion[]
}

// Snapshot of a document's content before an edit overwrote it (editor history, V1).
// Idempotency keys (T2.4): dedupe client-retried mutations so e.g. a retried
// generation doesn't double-charge quota. Claimed "pending" before the handler runs,
// flipped to "completed" with the stored response after.
model IdempotencyKey {
  id           String   @id @default(cuid())
  orgId        String
  key          String
  status       String   @default("pending")
  statusCode   Int?
  responseJson Json?
  createdAt    DateTime @default(now())

  @@unique([orgId, key])
  @@index([orgId])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  title       String
  contentJson Json
  // How the change at this point in the timeline was produced (T1.3): null = plain
  // edit; "tone-adjust" / "pricing-adjust" = AI adjustment.
  label       String?
  createdAt   DateTime @default(now())

  @@index([documentId])
}

model Subscription {
  id               String   @id @default(cuid())
  orgId            String   @unique
  org              Org      @relation(fields: [orgId], references: [id])
  stripeSubId      String   @unique
  stripePriceId    String
  status           String
  currentPeriodEnd DateTime
}

model LlmConfig {
  id              String    @id @default(cuid())
  orgId           String?   @unique
  provider        LlmVendor
  apiKeyEncrypted String
  model           String
  updatedAt       DateTime  @updatedAt
}

model GenerationLog {
  id               String   @id @default(cuid())
  orgId            String
  org              Org      @relation(fields: [orgId], references: [id])
  jobId            String
  provider         String
  model            String
  promptTokens     Int
  completionTokens Int
  costUsd          Decimal  @db.Decimal(10, 6)
  priceMapVersion  String
  createdAt        DateTime @default(now())
}

model SuperAdmin {
  id           String              @id @default(cuid())
  email        String              @unique
  // H3: real auth. Nullable so the legacy seed row keeps working until a password
  // is set; login is refused for rows without a hash.
  passwordHash String?
  // TOTP MFA (security #8): encrypted shared secret + the moment enrollment was
  // confirmed. While totpEnabledAt is null the secret is "pending" (not enforced).
  totpSecret    String?
  totpEnabledAt DateTime?
  createdAt    DateTime            @default(now())
  auditLogs    SuperAdminAuditLog[]
}

// H3: audit trail for the super-admin surface. Every authenticated /admin call is
// recorded (never the request body — it can carry secrets like LLM API keys).
model SuperAdminAuditLog {
  id           String     @id @default(cuid())
  superAdminId String
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id])
  action       String     // e.g. "PUT /admin/llm-config"
  ip           String?
  createdAt    DateTime   @default(now())

  @@index([superAdminId, createdAt])
}

// Atomic per-period quota counter (H2). Replaces counting GenerationLog rows,
// which had a check-then-insert race: two concurrent generations at the limit
// boundary could both pass. The guard reserves a slot with a single atomic
// INSERT .. ON CONFLICT DO UPDATE .. WHERE used < limit, so concurrency can
// never exceed the plan limit. A failed generation releases its reservation.
model QuotaPeriod {
  id          String   @id @default(cuid())
  orgId       String
  periodStart DateTime
  used        Int      @default(0)

  @@unique([orgId, periodStart])
}

// Persistent per-freelancer memory (V1). Small, org-scoped key/value facts the
// AI reuses across proposals (preferred tone, boilerplate, rates, do/don'ts).
// `value` is plaintext, OR AES-256-GCM ciphertext when `sensitive=true`. Rows are
// soft-deleted (deletedAt) so a purge is reversible and never breaks the unique key.
model UserMemory {
  id          String    @id @default(cuid())
  orgId       String
  org         Org       @relation(fields: [orgId], references: [id])
  category    String
  key         String
  value       String            // plaintext, OR ciphertext when sensitive=true
  confidence  Float     @default(1)
  source      String    @default("manual")   // manual | explicit | conversation | outcome | profile
  isPermanent Boolean   @default(true)
  sensitive   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastUsedAt  DateTime?
  deletedAt   DateTime?
  metadata    Json?

  @@unique([orgId, category, key])
}

// Complete audit trail of memory changes (V1). Best-effort append-only log written
// alongside create/update/delete/import. PRIVACY: `detail` NEVER stores a decrypted
// sensitive value — sensitive facts record only { sensitive: true }.
model MemoryAuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  memoryId  String?
  action    String
  category  String?
  key       String?
  detail    Json?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
}

model ProcessedEvent {
  id        String   @id            // Stripe event id
  createdAt DateTime @default(now())
}

// Anonymous free-trial usage (pre-auth). Lets a non-authenticated visitor get the
// "Should I Apply?" verdict + one proposal without signing up, while tracking usage
// server-side to deter abuse. NOT tenant-scoped — there is no org/user yet, so it is
// deliberately absent from TENANT_KEY. PRIVACY: stores HASHES ONLY (never raw
// IP / user-agent / fingerprint); `country` is coarse (header-derived) and optional.
model TrialUsage {
  id              String   @id @default(cuid())
  deviceId        String   @unique              // sha256(fingerprint + ua + tz + lang + platform)
  fingerprintHash String
  ipHash          String
  uaHash          String
  country         String?
  verdictCount    Int      @default(0)
  proposalCount   Int      @default(0)
  tokenUsed       Int      @default(0)
  trialUsed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([ipHash])
  @@index([fingerprintHash])
}

enum WebhookStatus {
  pending
  processing
  done
  failed
}

// Durable inbox for Stripe webhooks (H1). The webhook endpoint verifies the
// signature, persists the event here, and acks immediately (202). A background
// processor drains pending rows — so a slow/failed DB write can no longer make
// Stripe time out and retry, and unprocessed events survive a crash/restart.
model WebhookEvent {
  id          String        @id            // Stripe event id (dedup key)
  type        String
  payload     Json
  status      WebhookStatus @default(pending)
  attempts    Int           @default(0)
  lastError   String?
  createdAt   DateTime      @default(now())
  claimedAt   DateTime?     // when a worker last took the row into `processing`
  processedAt DateTime?

  @@index([status])
}
