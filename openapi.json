  "info": {
    "title": "WinProp API",
    "description": "",
    "version": "1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "HealthDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "SignupDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          },
          "name": {
            "type": "string"
          },
          "agencyName": {
            "type": "string"
          },
          "profession": {
            "type": "string",
            "enum": [
              "developer",
              "designer",
              "writer",
              "sales",
              "marketer",
              "consultant",
              "video"
            ]
          }
        },
        "required": [
          "email",
          "password",
          "name",
          "agencyName",
          "profession"
        ]
      },
      "AuthTokenDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          }
        },
        "required": [
          "accessToken"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "CreateJobDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "company": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ]
      },
      "JobDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "orgId": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "company": {
            "type": "string"
          },
          "status": {
            "enum": [
              "active",
              "won"
            ],
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "orgId",
          "title",
          "company",
          "status",
          "createdAt"
        ]
      },
      "SetLlmDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": [
              "openai",
              "anthropic"
            ]
          },
          "model": {
            "type": "string"
          },
          "apiKey": {
            "type": "string"
          }
        },
        "required": [
          "provider",
          "model",
          "apiKey"
        ]
      },
      "OkDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          }
        },
        "required": [
          "ok"
        ]
      },
      "LlmStatusDto": {
        "type": "object",
        "properties": {
          "isSet": {
            "type": "boolean"
          },
          "provider": {
            "nullable": true,
            "enum": [
              "openai",
              "anthropic"
            ],
            "type": "string"
          },
          "model": {
            "type": "string",
            "nullable": true
          },
          "updatedAt": {
            "type": "string",
            "nullable": true,
            "format": "date-time"
          }
        },
        "required": [
          "isSet",
          "provider",
          "model",
          "updatedAt"
        ]
      },
      "OrgSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "profession": {
            "enum": [
              "developer",
              "designer",
              "writer",
              "sales",
              "marketer",
              "consultant",
              "video"
            ],
            "type": "string"
          },
          "plan": {
            "enum": [
              "free",
              "solo",
              "pro",
              "agency"
            ],
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "profession",
          "plan"
        ]
      },
      "DocumentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "jobId": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "proposal"
            ]
          },
          "title": {
            "type": "string"
          },
          "contentJson": {
            "type": "object",
            "additionalProperties": true
          },
          "version": {
            "type": "number"
          },
          "status": {
            "enum": [
              "draft",
              "ready"
            ],
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "jobId",
          "type",
          "title",
          "contentJson",
          "version",
          "status",
          "createdAt"
        ]
      },
      "CheckoutDto": {
        "type": "object",
        "properties": {
          "plan": {
            "type": "string",
            "enum": [
              "solo",
              "pro",
              "agency"
            ]
          }
        },
        "required": [
          "plan"
        ]
      },
      "CheckoutSessionDto": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "url"
        ]
      },
      "WebhookReceivedDto": {
        "type": "object",
        "properties": {
          "received": {
            "type": "boolean"
          }
        },
        "required": [
          "received"
        ]
      },
      "UpdateLanguageDto": {
        "type": "object",
        "properties": {
          "language": {
            "type": "string",
            "enum": [
              "en",
              "ur",
              "ar",
              "fr",
              "es",
              "hi",
              "pt",
              "bn",
              "ru",
              "zh"
            ]
          }
        },
        "required": [
          "language"
        ]
      },
      "LanguageUpdatedDto": {
        "type": "object",
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "language": {
            "type": "string"
          }
        },
        "required": [
          "ok",
          "language"
        ]
      }
    }
  }
}